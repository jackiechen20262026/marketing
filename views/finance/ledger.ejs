<div class="page-head">
  <div>
    <h1 class="page-title">财务流水</h1>
    <div class="page-sub">
      当前余额：<span class="mono"><%= Number(currentBalance || 0).toFixed(2) %></span>
      <span class="muted">｜作废不会删除，余额链会自动重算</span>
    </div>
  </div>

  <div class="page-actions">
    <a class="btn btn-outline" href="/portal/finance-ledger">清空筛选</a>
  </div>
</div>

<div class="grid-2">
  <!-- 左：列表 -->
  <div>
    <div class="card">
      <div class="card-head">
        <div class="card-title">筛选</div>
        <div class="small">共 <%= pager.total %> 条</div>
      </div>

      <form method="get" class="form-grid">
        <div>
          <div class="label">开始日期</div>
          <input type="date" name="start" value="<%= filters.start || '' %>">
        </div>
        <div>
          <div class="label">结束日期</div>
          <input type="date" name="end" value="<%= filters.end || '' %>">
        </div>

        <div>
          <div class="label">类型</div>
          <select name="type">
            <option value="" <%= !filters.type ? 'selected' : '' %>>全部</option>
            <option value="IN" <%= filters.type==='IN' ? 'selected' : '' %>>收入</option>
            <option value="OUT" <%= filters.type==='OUT' ? 'selected' : '' %>>支出</option>
          </select>
        </div>

        <div>
          <div class="label">状态</div>
          <select name="status">
            <option value="" <%= !filters.status ? 'selected' : '' %>>全部</option>
            <option value="NORMAL" <%= filters.status==='NORMAL' ? 'selected' : '' %>>正常</option>
            <option value="VOID" <%= filters.status==='VOID' ? 'selected' : '' %>>作废</option>
          </select>
        </div>

        <div class="span-2">
          <div class="label">分类</div>
          <input name="category" placeholder="如：运费/样品/广告" value="<%= filters.category || '' %>">
        </div>

        <div class="span-2">
          <div class="label">关键词</div>
          <input name="kw" placeholder="备注/操作人" value="<%= filters.kw || '' %>">
        </div>

        <input type="hidden" name="pageSize" value="<%= filters.pageSize %>">

        <div>
          <button class="btn" type="submit">查询</button>
        </div>
        <div>
          <select name="pageSize" onchange="this.form.submit()">
            <% [20,50,100,200].forEach(s=>{ %>
              <option value="<%= s %>" <%= Number(filters.pageSize)===s ? 'selected' : '' %>><%= s %>/页</option>
            <% }) %>
          </select>
        </div>
      </form>

      <div class="divider"></div>

      <!-- 本月条形进度：收入 vs 支出 -->
      <%
        const totalIn = Number(monthStats?.total_in || 0);
        const totalOut = Number(monthStats?.total_out || 0);
        const total = totalIn + totalOut;
        const inPct = total ? (totalIn / total) * 100 : 0;
      %>

      <div class="card-head" style="margin:0 0 8px 0;">
        <div class="card-title">本月收入/支出</div>
        <div class="small mono"><%= totalIn.toFixed(2) %> / <%= totalOut.toFixed(2) %></div>
      </div>

      <div class="fin-bar">
        <div class="fin-bar-in" style="width:<%= inPct %>%"></div>
      </div>
      <div class="small muted" style="margin-top:8px;">
        收入占比 <%= inPct.toFixed(0) %>% ｜ 支出占比 <%= (100 - inPct).toFixed(0) %>%
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <div class="card-title">流水列表</div>
        <div class="small">
          第 <%= pager.page %>/<%= pager.totalPages %> 页
        </div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>日期</th>
              <th>类型</th>
              <th>金额</th>
              <th>余额</th>
              <th>分类</th>
              <th>备注</th>
              <th>操作人</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (!rows || rows.length===0) { %>
              <tr><td colspan="8" class="muted">暂无数据</td></tr>
            <% } %>

            <% rows.forEach(r=>{ %>
              <tr class="<%= r.status==='VOID' ? 'fin-void' : '' %>">
                <td class="mono"><%= r.txn_date %></td>
                <td>
                  <% if (r.type==='IN') { %>
                    <span class="tag">收入</span>
                  <% } else { %>
                    <span class="tag">支出</span>
                  <% } %>
                  <% if (r.status==='VOID') { %>
                    <span class="pill" style="margin-left:6px;">作废</span>
                  <% } %>
                </td>
                <td class="mono">
                  <% if (r.type==='IN') { %>
                    <span style="color:var(--success);font-weight:500;">+<%= Number(r.amount).toFixed(2) %></span>
                  <% } else { %>
                    <span style="color:var(--danger);font-weight:500;">-<%= Number(r.amount).toFixed(2) %></span>
                  <% } %>
                </td>
                <td class="mono"><%= Number(r.balance_after).toFixed(2) %></td>
                <td><%= r.category || '' %></td>
                <td class="muted">
                  <%= r.note || '' %>
                  <% if (r.status==='VOID' && r.void_reason) { %>
                    <div class="small">原因：<%= r.void_reason %></div>
                  <% } %>
                </td>
                <td><%= r.operator_name || '' %></td>
                <td>
                  <% if (r.status==='NORMAL') { %>
                    <form method="post" action="/portal/finance-ledger/<%= r.id %>/void" style="display:flex;gap:8px;align-items:center;">
                      <input name="reason" placeholder="作废原因" style="width:160px;" />
                      <button class="btn btn-muted" type="submit">作废</button>
                    </form>
                  <% } else { %>
                    <span class="muted">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;gap:10px;flex-wrap:wrap;">
        <div class="small muted">
          每页 <%= pager.pageSize %> 条，共 <%= pager.total %> 条
        </div>

        <div style="display:flex;gap:8px;align-items:center;">
          <%
            const qs = (k,v) => {
              const f = filters || {};
              const p = new URLSearchParams({
                start: f.start||'',
                end: f.end||'',
                type: f.type||'',
                status: f.status||'',
                kw: f.kw||'',
                category: f.category||'',
                pageSize: String(f.pageSize||50),
                page: String(v),
              });
              return p.toString();
            };
          %>

          <% if (pager.page > 1) { %>
            <a class="btn btn-outline" href="/portal/finance-ledger?<%= qs('page', pager.page-1) %>">上一页</a>
          <% } %>
          <% if (pager.page < pager.totalPages) { %>
            <a class="btn btn-outline" href="/portal/finance-ledger?<%= qs('page', pager.page+1) %>">下一页</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- 右：新增 -->
  <div>
    <div class="card">
      <div class="card-head">
        <div class="card-title">新增流水</div>
        <div class="small muted">支持补录历史日期，系统会自动重算余额链</div>
      </div>

      <form method="post" action="/portal/finance-ledger" class="form-grid">
        <div class="span-2">
          <div class="label">发生日期</div>
          <input type="date" name="txn_date" required>
        </div>

        <div>
          <div class="label">类型</div>
          <select name="type">
            <option value="IN">收入</option>
            <option value="OUT">支出</option>
          </select>
        </div>

        <div>
          <div class="label">金额</div>
          <input type="number" step="0.01" min="0.01" name="amount" required placeholder="0.00">
        </div>

        <div class="span-2">
          <div class="label">分类</div>
          <input name="category" placeholder="如：运费/样品/广告">
        </div>

        <div class="span-4">
          <div class="label">备注</div>
          <textarea name="note" rows="3" placeholder="可填写付款方/收款方/用途等"></textarea>
        </div>

        <div class="span-4" style="display:flex;justify-content:flex-end;">
          <button class="btn" type="submit">保存</button>
        </div>
      </form>

      <div class="divider"></div>
      <div class="small muted">
        规则：<span class="mono">NORMAL</span> 参与余额计算；<span class="mono">VOID</span> 不参与（但会保留记录与审计信息）。
      </div>
    </div>
  </div>
</div>