<div class="page">
  <div class="page__header page__header--sticky">
    <div>
      <div class="h1"><%= t("用户管理") %></div>
      <div class="sub"><%= t("创建用户、设置角色、停用账号（不可删除）") %></div>
    </div>
    <div class="page__actions">
      <a class="btn btn--primary" href="/portal/users/new"><%= t("新增用户") %></a>
      <a class="btn btn--ghost" href="/logout"><%= t("退出登录") %></a>
    </div>
  </div>

  <% if (success) { %><div class="alert alert--ok"><%= success %></div><% } %>
  <% if (error) { %><div class="alert alert--err"><%= error %></div><% } %>

  <div class="card">
    <div class="card__hd"><div class="card__title"><%= t("筛选") %></div></div>
    <form class="filters" method="get" action="/portal/users">
      <input class="input" name="keyword" value="<%= keyword || '' %>" placeholder="<%= t("搜索 username / name") %>">
      <select class="select" name="role">
        <option value=""><%= t("全部角色") %></option>
        <option value="admin" <%= role==='admin'?'selected':'' %>>admin</option>
        <option value="staff" <%= role==='staff'?'selected':'' %>>staff</option>
      </select>
      <select class="select" name="status">
        <option value=""><%= t("全部状态") %></option>
        <option value="active" <%= status==='active'?'selected':'' %>><%= t("启用") %></option>
        <option value="disabled" <%= status==='disabled'?'selected':'' %>><%= t("停用") %></option>
      </select>
      <button class="btn btn--primary" type="submit"><%= t("查询") %></button>
      <a class="btn btn--ghost" href="/portal/users"><%= t("清空") %></a>
    </form>
  </div>

  <div class="card">
    <div class="card__hd"><div class="card__title"><%= t("用户列表") %></div></div>

    <div class="table">
      <div class="tr tr--head">
        <div class="td">ID</div>
        <div class="td">username</div>
        <div class="td"><%= t("姓名") %></div>
        <div class="td"><%= t("角色") %></div>
        <div class="td"><%= t("状态") %></div>
        <div class="td"><%= t("创建时间") %></div>
        <div class="td"><%= t("操作") %></div>
      </div>

      <% (rows || []).forEach(r => { %>
        <div class="tr">
          <div class="td mono"><%= r.id %></div>
          <div class="td mono"><%= r.username %></div>
          <div class="td"><%= r.name || '-' %></div>
          <div class="td"><span class="tag"><%= r.role %></span></div>
          <div class="td">
            <span class="<%= r.status==='active'?'pill-ok':'pill-off' %>">
              <%= r.status==='active' ? t("启用") : t("停用") %>
            </span>
          </div>
          <div class="td mono"><%= r.created_at %></div>
          <div class="td">
            <a class="link" href="/portal/users/<%= r.id %>/edit"><%= t("编辑") %></a>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="pager">
      <div class="muted small">
        <%= t("共") %> <%= (pagination && pagination.total) || 0 %> <%= t("条") %>
        · <%= t("第") %> <%= (pagination && pagination.page) || 1 %> / <%= (pagination && pagination.totalPages) || 1 %> <%= t("页") %>
      </div>

      <div class="pager__actions">
        <% const pg = pagination || {page:1,totalPages:1}; %>
        <% const q = (k,v)=> `${encodeURIComponent(k)}=${encodeURIComponent(v||'')}`; %>
        <% const baseQs = [q('keyword',keyword),q('role',role),q('status',status)].join('&'); %>
        <a class="btn btn--ghost <%= pg.page<=1?'btn--disabled':'' %>" href="/portal/users?<%= baseQs %>&page=<%= Math.max(1,pg.page-1) %>"><%= t("上一页") %></a>
        <a class="btn btn--ghost <%= pg.page>=pg.totalPages?'btn--disabled':'' %>" href="/portal/users?<%= baseQs %>&page=<%= Math.min(pg.totalPages,pg.page+1) %>"><%= t("下一页") %></a>
      </div>
    </div>
  </div>
</div>

<style>
  .page__header{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:14px;}
  .page__header--sticky{position:sticky;top:0;z-index:20;background:#f8fafc;padding:14px 0;border-bottom:1px solid #eef2f7;}
  .page__actions{display:flex;gap:10px;flex-wrap:wrap;}
  .h1{font-size:22px;font-weight:700;}
  .sub{margin-top:6px;font-size:12px;color:#6b7280;}

  .alert{margin:0 0 12px 0;padding:10px 12px;border-radius:14px;font-size:13px;border:1px solid #e5e7eb;background:#fff;}
  .alert--ok{border-color:#bbf7d0;background:#f0fdf4;color:#166534;}
  .alert--err{border-color:#fecaca;background:#fef2f2;color:#991b1b;}

  .filters{display:grid;grid-template-columns: 1fr 180px 180px 120px 120px;gap:10px;align-items:center;}
  .table{display:flex;flex-direction:column;border:1px solid #f1f5f9;border-radius:14px;overflow:hidden;}
  .tr{display:grid;grid-template-columns:80px 180px 1fr 120px 120px 220px 120px;gap:10px;padding:12px;border-bottom:1px solid #f1f5f9;background:#fff;align-items:center;}
  .tr--head{background:#f9fafb;color:#6b7280;font-size:12px;}
  .td{min-width:0;}
  .mono{font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono","Courier New", monospace;}
  .tag{display:inline-block;padding:2px 10px;border-radius:999px;background:#f1f5f9;color:#111827;font-size:12px;}
  .pill-ok{display:inline-block;padding:2px 10px;border-radius:999px;background:#ecfdf5;color:#065f46;border:1px solid #a7f3d0;font-size:12px;}
  .pill-off{display:inline-block;padding:2px 10px;border-radius:999px;background:#fef2f2;color:#991b1b;border:1px solid #fecaca;font-size:12px;}
  .pager{display:flex;justify-content:space-between;align-items:center;margin-top:12px;}
  .pager__actions{display:flex;gap:10px;}
  .small{font-size:12px;}
  .muted{color:#6b7280;}
  .btn--disabled{pointer-events:none;opacity:.5;}

  @media (max-width: 980px){
    .filters{grid-template-columns:1fr; }
    .tr{grid-template-columns:1fr;}
  }
</style>