<%
// views/portal/batch_select_leads.ejs
%>

<%
  function q(v){ return encodeURIComponent(v || ""); }
%>

<div class="page-head">
  <div>
    <h1 class="page-title"><%= t("选择线索") %></h1>
    <div class="page-sub">
      <span class="pill"><%= t("批次") %>：<%= batchName %></span>
      <% if (remark) { %>
        <span class="small" style="margin-left:8px;"><%= remark %></span>
      <% } %>
    </div>
  </div>

  <div class="page-actions">
    <!-- ✅ 预留：推荐规则入口（下一步你要做规则设置） -->
    <a class="btn btn-outline" href="#" onclick="alert('下一步做：推荐线索规则设置');return false;"><%= t("推荐规则") %></a>

    <a class="btn btn-outline"
       href="/portal/batches/new?name=<%= q(batchName) %>&remark=<%= q(remark) %>"><%= t("返回上一步") %></a>

    <button class="btn" type="button" id="btnSubmitCreateTop"><%= t("创建批次") %></button>
  </div>
</div>

<div class="card">
  <div class="card-head">
    <div class="card-title"><%= t("筛选条件") %></div>
  </div>

  <form class="form-grid" method="get" action="/portal/batches/new/select">
    <input type="hidden" name="name" value="<%= batchName %>">
    <input type="hidden" name="remark" value="<%= remark || '' %>">

    <div class="span-2">
      <div class="label"><%= t("关键词") %></div>
      <input name="keyword" value="<%= keyword || '' %>" placeholder="公司名 / VAT / 统一号 / 关键词">
    </div>

    <div>
      <div class="label"><%= t("阶段") %></div>
      <select name="stage">
        <option value=""><%= t("全部阶段") %></option>
        <% STAGES.forEach(s => { %>
          <option value="<%= s %>" <%= stage===s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>

    <div>
      <div class="label"><%= t("等级") %></div>
      <select name="level">
        <option value=""><%= t("全部等级") %></option>
        <% LEVELS.forEach(l => { %>
          <option value="<%= l %>" <%= level===l ? 'selected' : '' %>><%= l %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-4" style="display:flex;gap:10px;align-items:flex-end;">
      <button class="btn" type="submit"><%= t("搜索") %></button>
      <a class="btn btn-outline"
         href="/portal/batches/new/select?name=<%= q(batchName) %>&remark=<%= q(remark) %>"><%= t("重置") %></a>
    </div>
  </form>
</div>

<div class="card">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:10px;">
    <div class="muted">
      共 <%= pagination.total %> 条 · 第 <%= pagination.page %>/<%= pagination.totalPages %> 页
      · <span class="pill"><%= t("已选") %>：<span id="selectedCount">0</span></span>
    </div>

    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <% if (pagination.page > 1) { %>
        <a class="btn btn-outline"
           href="/portal/batches/new/select?name=<%= q(batchName) %>&remark=<%= q(remark) %>&page=<%= pagination.page-1 %>&keyword=<%= q(keyword) %>&stage=<%= q(stage) %>&level=<%= q(level) %>">上一页</a>
      <% } else { %>
        <span class="btn btn-outline" style="opacity:.4;pointer-events:none;">上一页</span>
      <% } %>

      <% if (pagination.page < pagination.totalPages) { %>
        <a class="btn btn-outline"
           href="/portal/batches/new/select?name=<%= q(batchName) %>&remark=<%= q(remark) %>&page=<%= pagination.page+1 %>&keyword=<%= q(keyword) %>&stage=<%= q(stage) %>&level=<%= q(level) %>">下一页</a>
      <% } else { %>
        <span class="btn btn-outline" style="opacity:.4;pointer-events:none;">下一页</span>
      <% } %>
    </div>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="width:44px;"><input type="checkbox" id="chkAll"></th>
          <th style="width:90px;">ID</th>
          <th><%= t("公司") %></th>
          <th style="width:140px;"><%= t("城市") %></th>
          <th style="width:160px;"><%= t("品类") %></th>
          <th style="width:90px;"><%= t("等级") %></th>
          <th style="width:120px;"><%= t("阶段") %></th>
          <th style="width:140px;"><%= t("操作") %></th>
        </tr>
      </thead>
      <tbody>
        <% if (!rows || rows.length===0) { %>
          <tr><td colspan="8" class="muted" style="text-align:center;padding:22px;">暂无数据</td></tr>
        <% } else { %>
          <% rows.forEach(r => { %>
            <tr>
              <td><input type="checkbox" class="chkOne" value="<%= r.id %>"></td>
              <td class="mono"><%= r.id %></td>
              <td>
                <div style="font-weight:600;"><%= r.company_name %></div>
                <div class="small"><%= r.country || '' %></div>
              </td>
              <td><%= r.city || '' %></td>
              <td><%= r.category || '' %></td>
              <td><span class="pill"><%= r.customer_level || '' %></span></td>
              <td><span class="tag"><%= r.workflow_stage || '' %></span></td>
              <td><a class="link" href="/portal/leads/<%= r.id %>" target="_blank">查看</a></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- ✅ 创建批次提交表单（由 JS 写入 ids） -->
  <form id="createBatchFinal" method="post" action="/portal/batches" style="margin-top:14px;">
    <input type="hidden" name="name" value="<%= batchName %>">
    <input type="hidden" name="remark" value="<%= remark || '' %>">
    <input type="hidden" name="ids" id="idsInput" value="">
    <div style="display:flex;justify-content:flex-end;gap:10px;">
      <button class="btn btn-outline" type="button" onclick="window.scrollTo({top:0,behavior:'smooth'})"><%= t("回到顶部") %></button>
      <button class="btn" type="button" id="btnSubmitCreate"><%= t("创建批次") %></button>
    </div>
  </form>
</div>

<script>
  const chkAll = document.getElementById("chkAll");
  const idsInput = document.getElementById("idsInput");
  const selectedCount = document.getElementById("selectedCount");

  // ✅ 当前页勾选（后续如果要跨页保留，我们再做 localStorage/session）
  function getSelectedIds() {
    return Array.from(document.querySelectorAll(".chkOne:checked")).map(x => x.value);
  }

  function syncIds() {
    const ids = getSelectedIds();
    idsInput.value = ids.join(",");
    selectedCount.textContent = String(ids.length);
  }

  chkAll?.addEventListener("change", (e) => {
    document.querySelectorAll(".chkOne").forEach(chk => chk.checked = e.target.checked);
    syncIds();
  });

  document.querySelectorAll(".chkOne").forEach(chk => chk.addEventListener("change", syncIds));

  function submitCreate() {
    syncIds();
    if (!idsInput.value) {
      alert("请先勾选线索，再创建批次");
      return;
    }
    document.getElementById("createBatchFinal").submit();
  }

  document.getElementById("btnSubmitCreate")?.addEventListener("click", submitCreate);
  document.getElementById("btnSubmitCreateTop")?.addEventListener("click", submitCreate);

  // init
  syncIds();
</script>