<%
// views/portal/lead_edit.ejs
// 说明：controller 已经把 lead “扁平化”了（把主收件人字段合并进 lead），所以这里直接读 lead.receiver_* 即可
const l = lead || {};
function toDateValue(v){
  if(!v) return '';
  try{
    const d = (v instanceof Date) ? v : new Date(v);
    if(Number.isNaN(d.getTime())) return String(v).slice(0,10);
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth()+1).padStart(2,'0');
    const dd = String(d.getDate()).padStart(2,'0');
    return `${yyyy}-${mm}-${dd}`;
  }catch(e){
    return String(v||'').slice(0,10);
  }
}
%>

<div class="page">
  <div class="page__header page__header--sticky">
    <div>
      <div class="h1"><%= t("编辑线索") %> #<%= l.id %></div>
      <div class="sub"><%= t("详情页/修改页显示 VAT 与统一号；列表页不显示") %></div>
    </div>
    <div class="page__actions">
      <a class="btn btn--ghost" href="/portal/leads/<%= l.id %>"><%= t("返回详情") %></a>
      <a class="btn btn--ghost" href="/portal/lead-pool"><%= t("返回列表") %></a>
    </div>
  </div>

  <% if (error) { %>
    <div class="alert alert--err"><%= error %></div>
  <% } %>

  <!-- ✅ 路由：/update -->
  <form method="post" action="/portal/leads/<%= l.id %>/update" class="stack">

    <!-- 公司与工商信息 -->
    <div class="card">
      <div class="card__hd">
        <div class="card__title"><%= t("公司与工商信息") %></div>
      </div>

      <div class="grid4">
        <div class="field span2">
          <div class="label"><%= t("公司名称") %> *</div>
          <input class="input" name="company_name" value="<%= l.company_name || '' %>" required>
        </div>

        <div class="field">
          <div class="label"><%= t("公司英文名称") %></div>
          <input class="input" name="company_name_en" value="<%= l.company_name_en || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("亚马逊公司名称") %></div>
          <input class="input" name="amazon_company_name" value="<%= l.amazon_company_name || '' %>">
        </div>

        <div class="field">
          <div class="label">VAT</div>
          <input class="input" name="vat_no" value="<%= l.vat_no || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("统一社会信用代码") %></div>
          <input class="input" name="unified_code" value="<%= l.unified_code || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("法人") %></div>
          <input class="input" name="legal_person" value="<%= l.legal_person || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("注册资本") %></div>
          <input class="input" name="registered_capital" value="<%= l.registered_capital || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("注册日期") %></div>
          <input class="input" type="date" name="registration_date" value="<%= toDateValue(l.registration_date) %>">
        </div>
      </div>
    </div>

    <!-- 联系方式 -->
    <div class="card">
      <div class="card__hd">
        <div class="card__title"><%= t("联系方式") %></div>
      </div>

      <div class="grid4">
        <div class="field">
          <div class="label"><%= t("联系人") %></div>
          <input class="input" name="contact_name" value="<%= l.contact_name || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("电话") %></div>
          <input class="input" name="phone" value="<%= l.phone || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("邮箱") %></div>
          <input class="input" name="email" value="<%= l.email || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("微信号") %></div>
          <input class="input" name="wechat" value="<%= l.wechat || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("微信群代码") %></div>
          <input class="input" name="wechat_group_code" value="<%= l.wechat_group_code || '' %>">
        </div>

        <div class="field span2">
          <div class="label"><%= t("微信群二维码 URL") %></div>
          <input class="input" name="wechat_group_qr" value="<%= l.wechat_group_qr || '' %>">
        </div>
      </div>
    </div>

    <!-- 收件信息 -->
    <div class="card">
      <div class="card__hd">
        <div class="card__title"><%= t("收件信息（主收件人）") %></div>
      </div>

      <div class="grid4">
        <div class="field">
          <div class="label"><%= t("收件人") %> *</div>
          <input class="input" name="receiver_name" value="<%= l.receiver_name || '' %>" required>
        </div>

        <div class="field">
          <div class="label"><%= t("收件电话") %> *</div>
          <input class="input" name="receiver_mobile" value="<%= l.receiver_mobile || '' %>" required>
        </div>

        <div class="field">
          <div class="label"><%= t("省") %> *</div>
          <input class="input" name="receiver_province" value="<%= l.receiver_province || '' %>" required>
        </div>

        <div class="field">
          <div class="label"><%= t("市") %> *</div>
          <input class="input" name="receiver_city" value="<%= l.receiver_city || '' %>" required>
        </div>

        <div class="field">
          <div class="label"><%= t("区/县") %></div>
          <input class="input" name="receiver_county" value="<%= l.receiver_county || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("街道/镇") %></div>
          <input class="input" name="receiver_town" value="<%= l.receiver_town || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("邮编") %></div>
          <input class="input" name="receiver_postal_code" value="<%= l.receiver_postal_code || '' %>">
        </div>

        <div class="field span2">
          <div class="label"><%= t("详细地址") %> *</div>
          <input class="input" name="receiver_address" value="<%= l.receiver_address || '' %>" required>
        </div>

        <div class="field span4">
          <div class="small muted">
            <%= t("说明：线索表不保存地址；收件信息保存在 receiver_profiles，推送后会写入 shipments 快照。") %>
          </div>
        </div>
      </div>
    </div>

    <!-- 营销字段 -->
    <div class="card">
      <div class="card__hd">
        <div class="card__title"><%= t("营销字段") %></div>
      </div>

      <div class="grid4">
        <div class="field">
          <div class="label"><%= t("客户等级") %></div>
          <select class="select" name="customer_level">
            <% (LEVELS||[]).forEach(x => { %>
              <option value="<%= x %>" <%= (l.customer_level || 'C')===x ? 'selected':'' %>><%= x %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <div class="label"><%= t("阶段") %></div>
          <select class="select" name="workflow_stage">
            <% (STAGES||[]).forEach(x => { %>
              <option value="<%= x %>" <%= (l.workflow_stage || '已导入')===x ? 'selected':'' %>><%= x %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <div class="label"><%= t("优先级") %></div>
          <select class="select" name="priority">
            <% ['Low','Normal','High'].forEach(p => { %>
              <option value="<%= p %>" <%= (l.priority || 'Normal')===p ? 'selected':'' %>><%= p %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <div class="label"><%= t("来源") %></div>
          <input class="input" name="source" value="<%= l.source || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("品类") %></div>
          <input class="input" name="category" value="<%= l.category || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("官网") %></div>
          <input class="input" name="website" value="<%= l.website || '' %>">
        </div>

        <div class="field span2">
          <div class="label"><%= t("亚马逊店铺链接") %></div>
          <input class="input" name="amazon_shop_url" value="<%= l.amazon_shop_url || '' %>">
        </div>

        <div class="field">
          <div class="label"><%= t("品牌") %></div>
          <input class="input" name="brand" value="<%= l.brand || '' %>" placeholder="例如：Anasa">
        </div>

        <div class="field span2">
          <div class="label"><%= t("样品快递单号") %></div>
          <input class="input" name="sample_tracking_no" value="<%= l.sample_tracking_no || '' %>" placeholder="例如：YT123456789CN">
          <div class="small muted" style="margin-top:6px;"><%= t("填写后会自动进入【已寄样品】页面。") %></div>
        </div>

        <div class="field span4">
          <div class="label"><%= t("公司简介") %></div>
          <textarea class="textarea" name="company_profile" rows="4"><%= l.company_profile || '' %></textarea>
        </div>
      </div>

      <div class="actions">
        <a class="btn btn--ghost" href="/portal/leads/<%= l.id %>"><%= t("取消") %></a>
        <button class="btn btn--primary" type="submit"><%= t("保存") %></button>
      </div>
    </div>
  </form>
</div>

<style>
  .page__header{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:14px;}
  .page__header--sticky{position:sticky;top:0;z-index:20;background:#f8fafc;padding:14px 0;border-bottom:1px solid #eef2f7;}
  .page__actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
  .h1{font-size:22px;font-weight:700;}
  .sub{margin-top:6px;font-size:12px;color:#6b7280;}

  .stack{display:grid;gap:12px;}
  .card{background:#fff;border:1px solid #eef2f7;border-radius:16px;}
  .card__hd{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-bottom:1px solid #f1f5f9;}
  .card__title{font-weight:700;}
  .grid4{padding:12px 14px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px;align-items:end;}
  .span2{grid-column:span 2;}
  .span4{grid-column:span 4;}

  .label{font-size:12px;color:#6b7280;margin:0 0 6px 2px;}
  .input,.select,.textarea{width:100%;border:1px solid #e5e7eb;border-radius:14px;padding:10px 12px;background:#fff;font-size:13px;outline:none;}
  .textarea{resize:vertical;}
  .small{font-size:12px;}
  .muted{color:#6b7280;}

  .actions{padding:12px 14px;border-top:1px solid #f1f5f9;display:flex;justify-content:flex-end;gap:10px;}
  .btn{display:inline-flex;align-items:center;justify-content:center;height:36px;padding:0 12px;border-radius:14px;border:1px solid #e5e7eb;background:#fff;color:#111827;text-decoration:none;font-size:13px;cursor:pointer;}
  .btn--primary{border-color:#111827;background:#111827;color:#fff;}
  .btn--ghost{background:#fff;color:#111827;}
  .alert{margin:0 0 12px 0;padding:10px 12px;border-radius:14px;font-size:13px;border:1px solid #e5e7eb;background:#fff;}
  .alert--err{border-color:#fecaca;background:#fef2f2;color:#991b1b;}

  @media (max-width:980px){
    .grid4{grid-template-columns:1fr 1fr;}
    .span2,.span4{grid-column:span 2;}
  }
  @media (max-width:560px){
    .grid4{grid-template-columns:1fr;}
    .span2,.span4{grid-column:span 1;}
  }
</style>