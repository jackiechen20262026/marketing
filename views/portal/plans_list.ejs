<%
// views/portal/plans_list.ejs
const rowsSafe = rows || [];
const pg = pagination || { page: 1, pageSize: 20, total: 0, totalPages: 1 };

const keywordSafe = keyword || '';
const typeSafe = type || '';
const statusSafe = status || '';
const dateFromSafe = dateFrom || '';
const dateToSafe = dateTo || '';

const qsBase =
  `keyword=${encodeURIComponent(keywordSafe||'')}` +
  `&type=${encodeURIComponent(typeSafe||'')}` +
  `&status=${encodeURIComponent(statusSafe||'')}` +
  `&date_from=${encodeURIComponent(dateFromSafe||'')}` +
  `&date_to=${encodeURIComponent(dateToSafe||'')}`;
%>

<div class="page">
  <div class="page__header page__header--sticky">
    <div>
      <div class="h1"><%= t("总计划") %></div>
      <div class="sub"><%= t("所有线索的计划汇总（用于团队跟进）") %></div>
    </div>
    <div class="page__actions">
      <a class="btn btn--ghost" href="/portal/lead-pool"><%= t("返回线索池") %></a>
    </div>
  </div>

  <% if (success) { %><div class="alert alert--ok"><%= success %></div><% } %>
  <% if (error) { %><div class="alert alert--err"><%= error %></div><% } %>

  <div class="card">
    <div class="card__hd">
      <div class="card__title"><%= t("筛选") %></div>
    </div>

    <form class="filters" method="get" action="/portal/plans">
      <input class="input" name="keyword" value="<%= keywordSafe %>" placeholder="<%= t("搜索：公司/微信/电话/备注") %>">

      <select class="select" name="type">
        <option value=""><%= t("全部类型") %></option>
        <% (types||[]).forEach(x => { %>
          <option value="<%= x.key %>" <%= x.key===typeSafe?'selected':'' %>><%= x.name %></option>
        <% }) %>
      </select>

      <select class="select" name="status">
        <% (statuses||[]).forEach(x => { %>
          <option value="<%= x.key %>" <%= x.key===statusSafe?'selected':'' %>><%= x.name %></option>
        <% }) %>
      </select>

      <input class="input" type="date" name="date_from" value="<%= dateFromSafe %>">
      <input class="input" type="date" name="date_to" value="<%= dateToSafe %>">

      <button class="btn btn--primary" type="submit"><%= t("查询") %></button>
      <a class="btn btn--ghost" href="/portal/plans"><%= t("清空") %></a>
    </form>
  </div>

  <div class="card">
    <div class="card__hd">
      <div class="card__title"><%= t("计划列表") %></div>
      <div class="muted small"><%= t("共") %> <%= pg.total %> <%= t("条") %></div>
    </div>

    <div class="table">
      <div class="tr tr--head">
        <div class="td"><%= t("公司") %></div>
        <div class="td"><%= t("类型") %></div>
        <div class="td"><%= t("计划时间") %></div>
        <div class="td"><%= t("状态") %></div>
        <div class="td"><%= t("备注") %></div>
        <div class="td"><%= t("创建人") %></div>
        <div class="td"><%= t("操作") %></div>
      </div>

      <% if (!rowsSafe.length) { %>
        <div class="empty muted"><%= t("暂无计划") %></div>
      <% } %>

      <% rowsSafe.forEach(r => { %>
        <div class="tr">
          <div class="td strong">
            <a class="link" href="/portal/leads/<%= r.lead_id %>"><%= r.company_name || ('#'+r.lead_id) %></a>
          </div>
          <div class="td"><span class="tag"><%= r.plan_type || '-' %></span></div>
          <div class="td mono">
  <%
    let dateStr = '-';
    if (r.planned_at) {
      const d = new Date(r.planned_at);
      const yyyy = d.getFullYear();
      const mm = String(d.getMonth() + 1).padStart(2, '0');
      const dd = String(d.getDate()).padStart(2, '0');
      dateStr = `${yyyy}-${mm}-${dd}`;
    }
  %>
  <%= dateStr %>
</div>
          <div class="td">
            <span class="pill <%= r.status==='PLANNED' ? 'pill--blue' : (r.status==='DONE' ? 'pill--green' : 'pill--gray') %>">
              <%= r.status || '-' %>
            </span>
          </div>
          <div class="td pre muted"><%= r.plan_note || '' %></div>
          <div class="td muted"><%= r.created_by_name || '-' %></div>
          <div class="td">
            <a class="btn btn--ghost" href="/portal/leads/<%= r.lead_id %>/plans"><%= t("进入") %></a>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="pager">
      <div class="muted small">
        <%= t("第") %> <%= pg.page %> / <%= pg.totalPages %> <%= t("页") %>
      </div>
      <div class="pager__actions">
        <a class="btn btn--ghost <%= pg.page<=1 ? 'btn--disabled' : '' %>"
           href="/portal/plans?<%= qsBase %>&page=<%= Math.max(1, pg.page-1) %>"><%= t("上一页") %></a>
        <a class="btn btn--ghost <%= pg.page>=pg.totalPages ? 'btn--disabled' : '' %>"
           href="/portal/plans?<%= qsBase %>&page=<%= Math.min(pg.totalPages, pg.page+1) %>"><%= t("下一页") %></a>
      </div>
    </div>
  </div>
</div>

<style>
  .page__header{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:14px;}
  .page__header--sticky{position:sticky;top:0;z-index:20;background:#f8fafc;padding:14px 0;border-bottom:1px solid #eef2f7;}
  .page__actions{display:flex;gap:10px;flex-wrap:wrap;}
  .h1{font-size:22px;font-weight:700;}
  .sub{margin-top:6px;font-size:12px;color:#6b7280;}
  .small{font-size:12px;}
  .muted{color:#6b7280;}
  .strong{font-weight:700;}
  .mono{font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono","Courier New", monospace;}
  .pre{white-space:pre-wrap;}

  .alert{margin:0 0 12px 0;padding:10px 12px;border-radius:14px;font-size:13px;border:1px solid #e5e7eb;background:#fff;}
  .alert--ok{border-color:#bbf7d0;background:#f0fdf4;color:#166534;}
  .alert--err{border-color:#fecaca;background:#fef2f2;color:#991b1b;}

  .filters{display:grid;grid-template-columns: 1fr 160px 160px 160px 160px 120px 120px;gap:10px;align-items:center;}

  .table{display:flex;flex-direction:column;border:1px solid #f1f5f9;border-radius:14px;overflow:hidden;}
  .tr{display:grid;grid-template-columns: 1.4fr 120px 170px 120px 1.6fr 120px 90px;gap:10px;padding:12px;border-bottom:1px solid #f1f5f9;background:#fff;align-items:center;}
  .tr--head{background:#f9fafb;color:#6b7280;font-size:12px;}
  .tag{display:inline-block;padding:2px 10px;border-radius:999px;background:#f1f5f9;color:#111827;font-size:12px;}
  .pill{display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid #e5e7eb;font-size:12px;}
  .pill--blue{background:#eff6ff;border-color:#bfdbfe;color:#1d4ed8;}
  .pill--green{background:#f0fdf4;border-color:#bbf7d0;color:#166534;}
  .pill--gray{background:#f8fafc;border-color:#e5e7eb;color:#334155;}

  .empty{padding:12px;}

  .pager{display:flex;justify-content:space-between;align-items:center;margin-top:12px;}
  .pager__actions{display:flex;gap:10px;}
  .btn--disabled{pointer-events:none;opacity:.5;}

  @media (max-width: 980px){
    .filters{grid-template-columns:1fr;}
    .tr{grid-template-columns:1fr;}
  }
</style>